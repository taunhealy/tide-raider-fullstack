// Prisma Schema for Multi-Tenant Luxury Rental Booking SaaS
// Supports: Supercars, Yachts, Jet-skis, 4x4 Campers
// Database: Supabase Postgres via Prisma Accelerate

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_ACCELERATE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USERS (next-auth v5)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts Account[]
  sessions Session[]
  bookings Booking[] // Customer bookings
  reviews  Review[] // Customer reviews

  // Company ownership (for rental company owners)
  ownedCompanies Company[] @relation("CompanyOwner")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String // "google"
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// MULTI-TENANT: COMPANIES (Rental Businesses)
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // For subdomains/custom URLs
  description String?  @db.Text
  logo        String? // URL to logo
  email       String
  phone       String?
  website     String?
  address     String?
  city        String?
  province    String? // South African provinces
  country     String   @default("ZA")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  ownerId  String  @map("owner_id")
  owner    User    @relation("CompanyOwner", fields: [ownerId], references: [id])
  settings CompanySettings?
  listings Listing[]
  bookings Booking[]
  reviews  Review[]

  @@index([slug])
  @@index([ownerId])
  @@map("companies")
}

model CompanySettings {
  id        String   @id @default(cuid())
  companyId String   @unique @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Encrypted PayPal credentials (AES-256-GCM)
  paypalClientId     String? @map("paypal_client_id") @db.Text // Encrypted
  paypalClientSecret String? @map("paypal_client_secret") @db.Text // Encrypted
  paypalMode         String  @default("sandbox") @map("paypal_mode") // "sandbox" or "live"

  // Business settings
  currency              String  @default("ZAR")
  taxRate               Float   @default(0.15) @map("tax_rate") // 15% VAT in SA
  depositPercentage     Float   @default(0.30) @map("deposit_percentage") // 30% deposit
  cancellationPolicyDays Int    @default(7) @map("cancellation_policy_days")
  autoApproveBookings   Boolean @default(false) @map("auto_approve_bookings")

  // Weather-based dynamic pricing
  enableDynamicPricing Boolean @default(false) @map("enable_dynamic_pricing")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ============================================
// RENTAL INVENTORY (Listings)
// ============================================

enum ListingCategory {
  SUPERCAR
  YACHT
  JETSKI
  CAMPER_4X4
  SNOWBOARD
  SKIS
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Listing {
  id          String          @id @default(cuid())
  companyId   String          @map("company_id")
  title       String
  slug        String // URL-friendly
  description String          @db.Text
  category    ListingCategory
  status      ListingStatus   @default(DRAFT)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Pricing
  basePricePerDay    Float   @map("base_price_per_day") // Daily rate
  weeklyDiscount     Float   @default(0.10) @map("weekly_discount") // 10% off for 7+ days
  monthlyDiscount    Float   @default(0.20) @map("monthly_discount") // 20% off for 30+ days
  securityDeposit    Float   @default(0) @map("security_deposit")
  cleaningFee        Float   @default(0) @map("cleaning_fee")
  insurancePerDay    Float   @default(0) @map("insurance_per_day")

  // Availability
  minRentalDays      Int     @default(1) @map("min_rental_days")
  maxRentalDays      Int     @default(30) @map("max_rental_days")
  advanceNoticeDays  Int     @default(2) @map("advance_notice_days") // Book X days in advance

  // Location
  pickupLocation     String? @map("pickup_location")
  dropoffLocation    String? @map("dropoff_location")
  latitude           Float?
  longitude          Float?

  // Vehicle/Asset Details (flexible JSON)
  specifications     Json?   @db.JsonB // e.g., {make, model, year, seats, transmission}
  features           Json?   @db.JsonB // e.g., ["GPS", "Bluetooth", "Roof Rack"]
  addOns             Json?   @db.JsonB // e.g., [{name: "Camping Gear", price: 500}]

  // Relations
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  images       ListingImage[]
  bookings     Booking[]
  pricingRules PricingRule[]
  reviews      Review[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([category])
  @@index([status])
  @@map("listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String   @map("listing_id")
  url       String
  altText   String?  @map("alt_text")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ============================================
// BOOKINGS & PAYMENTS
// ============================================

enum BookingStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

model Booking {
  id        String        @id @default(cuid())
  companyId String        @map("company_id")
  listingId String        @map("listing_id")
  userId    String        @map("user_id")
  status    BookingStatus @default(PENDING_PAYMENT)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // Booking details
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  totalDays Int      @map("total_days")

  // Pricing breakdown (snapshot at booking time)
  basePrice       Float  @map("base_price")
  discountAmount  Float  @default(0) @map("discount_amount")
  taxAmount       Float  @default(0) @map("tax_amount")
  depositAmount   Float  @default(0) @map("deposit_amount")
  insuranceAmount Float  @default(0) @map("insurance_amount")
  addOnsAmount    Float  @default(0) @map("add_ons_amount")
  totalAmount     Float  @map("total_amount")
  currency        String @default("ZAR")

  // Customer details (snapshot)
  customerName  String @map("customer_name")
  customerEmail String @map("customer_email")
  customerPhone String @map("customer_phone")

  // Selected add-ons (snapshot)
  selectedAddOns Json?  @db.JsonB

  // Notes
  customerNotes String? @db.Text @map("customer_notes")
  adminNotes    String? @db.Text @map("admin_notes")

  // Relations
  company  Company   @relation(fields: [companyId], references: [id])
  listing  Listing   @relation(fields: [listingId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]
  review   Review?

  @@index([companyId])
  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@map("bookings")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @map("booking_id")
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // PayPal details
  paypalOrderId   String  @unique @map("paypal_order_id")
  paypalPayerId   String? @map("paypal_payer_id")
  paypalPayerEmail String? @map("paypal_payer_email")

  // Payment details
  amount         Float
  currency       String  @default("ZAR")
  paymentMethod  String  @default("paypal") @map("payment_method")

  // Webhook tracking
  webhookReceived Boolean @default(false) @map("webhook_received")
  webhookEventId  String? @map("webhook_event_id")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([paypalOrderId])
  @@map("payments")
}

model WebhookEvent {
  id         String   @id @default(cuid())
  eventId    String   @unique @map("event_id") // PayPal webhook event ID
  eventType  String   @map("event_type") // e.g., "PAYMENT.CAPTURE.COMPLETED"
  resourceId String   @map("resource_id") // e.g., paypal_order_id
  payload    Json     @db.JsonB
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([eventType])
  @@index([processed])
  @@map("webhook_events")
}

// ============================================
// DYNAMIC PRICING (Weather-based)
// ============================================

enum PricingRuleType {
  WEATHER_SUNNY
  WEATHER_RAINY
  WEATHER_WINDY
  PEAK_SEASON
  OFF_SEASON
  LAST_MINUTE
  EARLY_BIRD
}

model PricingRule {
  id         String          @id @default(cuid())
  listingId  String          @map("listing_id")
  name       String
  type       PricingRuleType
  multiplier Float // e.g., 1.2 = +20%, 0.8 = -20%
  isActive   Boolean         @default(true) @map("is_active")
  priority   Int             @default(0) // Higher priority rules apply first
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  // Weather conditions (for weather-based rules)
  minTemperature Float? @map("min_temperature")
  maxTemperature Float? @map("max_temperature")
  weatherCodes   Json?  @db.JsonB // WeatherAPI condition codes

  // Date range (for seasonal rules)
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([type])
  @@map("pricing_rules")
}

model WeatherCache {
  id        String   @id @default(cuid())
  location  String   @unique // "lat,lon" format
  data      Json     @db.JsonB // WeatherAPI response
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([location])
  @@index([expiresAt])
  @@map("weather_cache")
}

// ============================================
// REVIEWS & RATINGS
// ============================================

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique @map("booking_id")
  companyId String   @map("company_id")
  listingId String   @map("listing_id")
  userId    String   @map("user_id")
  rating    Int // 1-5 stars
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([listingId])
  @@index([userId])
  @@map("reviews")
}

// ============================================
// ADMIN LOGS (Future: Audit trail)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String // e.g., "CREATE_BOOKING", "UPDATE_LISTING"
  entityType String  @map("entity_type") // e.g., "Booking", "Listing"
  entityId  String   @map("entity_id")
  metadata  Json?    @db.JsonB
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

