generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdRequest {
  id                    String         @id
  companyName           String
  contactEmail          String
  imageUrl              String?
  linkUrl               String
  description           String?
  status                String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  rejectionReason       String?
  userId                String?
  category              String
  categoryData          Json?
  googleAdsCampaignId   String?
  googleAdsContribution Float
  regionId              String
  title                 String?
  yearlyPrice           Float
  startDate             DateTime
  endDate               DateTime
  variantId             String?
  paypalSubscriptionId  String?
  categoryType          String?        @default("local")
  customCategory        String?
  ad                    Ad?
  region                Region         @relation(fields: [regionId], references: [id])
  user                  User?          @relation(fields: [userId], references: [id])
  notifications         Notification[]

  @@index([regionId])
  @@index([category])
  @@index([status])
}

model Ad {
  id                   String              @id @default(uuid())
  requestId            String              @unique
  companyName          String
  title                String?
  description          String?
  category             String
  linkUrl              String
  imageUrl             String?
  regionId             String
  country              String?
  status               String              @default("active")
  startDate            DateTime
  endDate              DateTime
  paypalSubscriptionId String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  userId               String?
  categoryType         String?             @default("local")
  customCategory       String?
  region               Region              @relation(fields: [regionId], references: [id])
  adRequest            AdRequest           @relation(fields: [requestId], references: [id])
  user                 User?               @relation(fields: [userId], references: [id])
  beachConnections     AdBeachConnection[]
  clicks               AdClick[]
  notifications        Notification[]

  @@index([regionId])
  @@index([category])
  @@index([status])
  @@index([userId])
}

model AdBeachConnection {
  id      String @id @default(uuid())
  adId    String
  beachId String
  ad      Ad     @relation(fields: [adId], references: [id], onDelete: Cascade)
  beach   Beach  @relation(fields: [beachId], references: [id])

  @@unique([adId, beachId])
  @@index([adId])
  @@index([beachId])
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  emailVerified        DateTime?
  image                String?
  nationality          String?
  password             String?
  skillLevel           SkillLevel?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  lemonCustomerId      String?
  lemonSubscriptionId  String?
  savedFilters         Json?
  hasActiveTrial       Boolean             @default(false)
  hasTrialEnded        Boolean             @default(false)
  trialEndDate         DateTime?
  trialStartDate       DateTime?
  bio                  String?
  link                 String?
  subscriptionEndsAt   DateTime?
  subscriptionStatus   String?
  paypalSubscriptionId String?
  roles                UserRole[]          @default([SURFER])
  accounts             Account[]
  ads                  Ad[]
  adRequests           AdRequest[]
  alerts               Alert[]
  boards               Board[]
  comments             Comment[]
  events               Event[]
  hiddenGemsModerated  HiddenGem[]         @relation("ModeratedHiddenGems")
  hiddenGemsSubmitted  HiddenGem[]         @relation("HiddenGemSubmitter")
  logEntries           LogEntry[]
  membership           Membership?
  notifications        Notification[]
  rentalChatMessages   RentalChatMessage[]
  rentalItems          RentalItem[]
  ownedItemRequests    RentalItemRequest[] @relation("OwnerItemRequests")
  rentedItemRequests   RentalItemRequest[] @relation("RenterItemRequests")
  safariBookings       SafariBooking[]
  sessions             Session[]
  stories              Story[]
  surfSafaris          SurfSafariListing[]
  favorites            UserFavorite[]
  filters              UserFilters?
  bookingsAsGuest      Booking[]           @relation("BookingGuest")
  enquiriesAsGuest     Enquiry[]           @relation("EnquiryGuest")
  messagesSent         Message[]           @relation("MessageSender")
  propertiesAsHost     Property[]          @relation("PropertyHost")
  reviewsReceived      PropertyReview[]    @relation("Reviewee")
  reviewsGiven         PropertyReview[]    @relation("Reviewer")
  
  notificationPreferences UserNotificationPreference[]

  // Referral System
  referralCode         String?             @unique
  referredById         String?
  referredBy           User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals            User[]              @relation("UserReferrals")

  // Credits System
  credits              Int                 @default(5)

  // WhatsApp Number for Alerts
  whatsappNumber       String?

  // Squads
  squads Squad[]
  promoCodeUsages PromoCodeUsage[]
  
  // Partner / Referral System
  partnerProfile       PartnerProfile?
  ownedPromoCodes      PromoCode[]         @relation("PartnerPromoCodes")
  commissionsReceived  Commission[]        @relation("PartnerCommissions")
  commissionsGenerated Commission[]        @relation("ReferredCommissions")
  
  // AI Reports History
  intelligenceReports  IntelligenceReport[]

  @@index([email])
  @@index([skillLevel])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  country     String
  regionId    String
  startTime   DateTime
  link        String?
  createdAt   DateTime @default(now())
  userId      String
  region      Region   @relation(fields: [regionId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([regionId])
}

model LogEntry {
  id            String     @id @default(uuid())
  date          DateTime   @db.Date
  surferName    String?
  surferEmail   String?
  beachName     String?
  surferRating  Int        @default(0)
  comments      String?
  imageUrl      String?
  videoUrl      String?
  videoPlatform String?
  isPrivate     Boolean    @default(false)
  isAnonymous   Boolean    @default(false)
  waveType      String?
  beachId       String?
  userId        String?    @map("user_id")
  regionId      String
  category      SportCategory @default(GENERAL)
  forecastId    String?
  imageUrls     Json?
  hiddenGemId   String?
  alerts        Alert[]
  beach         Beach?     @relation(fields: [beachId], references: [id])
  forecast      Forecast?  @relation(fields: [forecastId], references: [id])
  hiddenGem     HiddenGem? @relation("HiddenGemLogs", fields: [hiddenGemId], references: [id])
  region        Region     @relation(fields: [regionId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])

  @@index([regionId])
  @@index([beachId])
  @@index([userId])
  @@index([forecastId])
  @@index([hiddenGemId])
}

model SafariBooking {
  id             String            @id @default(cuid())
  safariId       String
  userId         String
  date           DateTime
  bringingBoard  Boolean           @default(false)
  requiresRental Boolean           @default(false)
  skillLevel     SkillLevel
  status         BookingStatus     @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  boardId        String?
  board          Board?            @relation(fields: [boardId], references: [id])
  safari         SurfSafariListing @relation(fields: [safariId], references: [id])
  user           User              @relation(fields: [userId], references: [id])

  @@index([safariId])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([boardId])
}

model SurfSafariListing {
  id                     String                  @id @default(cuid())
  guideId                String
  title                  String
  description            String
  profileImage           String?
  price                  Float?
  isFree                 Boolean                 @default(false)
  hasVehicleTransport    Boolean                 @default(false)
  canTransportLongboard  Boolean                 @default(false)
  canTransportShortboard Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  beaches                BeachSafariConnection[]
  bookings               SafariBooking[]
  guide                  User                    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([isActive])
}

model BeachSafariConnection {
  id       String            @id @default(cuid())
  beachId  String
  safariId String
  distance Float?
  safari   SurfSafariListing @relation(fields: [safariId], references: [id])

  @@unique([beachId, safariId])
  @@index([safariId])
  @@index([beachId])
}

enum SportCategory {
  GENERAL
  LOGGING
  SURF_FOILING
  WING_FOILING
  DOWNWIND_FOILING
  KITESURFING
}

model BeachConditionProfile {
  id                     String        @id @default(cuid())
  beachId                String
  category               SportCategory @default(GENERAL)
  optimalWindDirections  String[]
  optimalSwellDirections Json
  optimalTide            OptimalTide
  swellSize              Json
  idealSwellPeriod       Json
  beach                  Beach         @relation(fields: [beachId], references: [id], onDelete: Cascade)

  @@unique([beachId, category])
}

model BeachDailyScore {
  id         String        @id @default(cuid())
  beachId    String
  regionId   String
  category   SportCategory @default(GENERAL)
  score      Int           @default(0)
  conditions Json
  date       DateTime
  timeSlot   TimeSlot      @default(MORNING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  starRating Int?
  source     String        @default("WINDFINDER")
  beach      Beach         @relation(fields: [beachId], references: [id])
  region     Region        @relation(fields: [regionId], references: [id])

  @@unique([beachId, date, source, timeSlot, category])
  @@index([regionId])
  @@index([beachId, date])
  @@index([starRating])
  @@index([source])
  @@index([regionId, date, source, timeSlot])
}

model IntelligenceReport {
  id          String   @id @default(cuid())
  beachId     String
  userId      String?  // Linked to who generated it (optional for global cache)
  date        DateTime @db.Date
  persona     String
  content     String   @db.Text
  duration    Int      @default(7)
  endDate     DateTime? @db.Date // End range for multi-day reports
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  beach       Beach    @relation(fields: [beachId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([beachId, userId, date, persona, duration], name: "intel_history_unique")
  @@index([beachId, date])
  @@index([userId])
}

model Beach {
  id                     String                  @id
  name                   String
  continent              String
  regionId               String
  location               String
  distanceFromCT         Float
  bestSeasons            Season[]
  description            String
  difficulty             Difficulty
  waveType               WaveType
  waterTemp              Json
  hazards                Hazard[]
  crimeLevel             CrimeLevel
  sharkAttack            SharkRisk
  image                  String?
  coordinates            Json
  videos                 Json?
  profileImage           String?
  advertisingPrice       Float?
  coffeeShop             Json?
  hasSharkAlert          Boolean?
  bestMonthOfYear        Month?
  isHiddenGem            Boolean?
  sheltered              Boolean?
  countryId              String
  isLongboarding         Boolean                 @default(false)
  isFoiling              Boolean                 @default(false)
  adConnections          AdBeachConnection[]
  alerts                 Alert[]
  country                Country                 @relation(fields: [countryId], references: [id])
  region                 Region                  @relation(fields: [regionId], references: [id])
  beachDailyScores       BeachDailyScore[]
  conditionProfiles      BeachConditionProfile[]
  rentalItems            BeachRentalConnection[]
  feedbacks              Feedback[]
  logEntries             LogEntry[]
  rentalItemRequests     RentalItemRequest[]
  stories                Story[]
  properties             Property[]
  broadcasts             Broadcast[]
  intelligenceReports    IntelligenceReport[]
  searches               UserSearch[]

  @@index([regionId])
  @@index([countryId])
  @@index([waveType])
  @@index([difficulty])
  @@index([isHiddenGem])
}

model HiddenGem {
  id                     String          @id @default(cuid())
  name                   String
  description            String
  location               String
  regionId               String
  countryId              String
  continent              String
  coordinates            Json
  waveType               WaveType
  difficulty             Difficulty
  optimalTide            OptimalTide
  bestSeasons            Season[]
  optimalWindDirections  String[]
  optimalSwellDirections Json?
  swellSize              Json?
  idealSwellPeriod       Json?
  hazards                Hazard[]
  crimeLevel             CrimeLevel?
  sharkRisk              SharkRisk?
  sheltered              Boolean         @default(false)
  crowdLevel             String?
  images                 String[]
  videos                 Json?
  submittedById          String
  status                 HiddenGemStatus @default(PENDING)
  moderatedById          String?
  moderationNotes        String?
  rejectionReason        String?
  viewCount              Int             @default(0)
  likeCount              Int             @default(0)
  verified               Boolean         @default(false)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  publishedAt            DateTime?
  country                Country         @relation(fields: [countryId], references: [id])
  moderatedBy            User?           @relation("ModeratedHiddenGems", fields: [moderatedById], references: [id])
  region                 Region          @relation(fields: [regionId], references: [id])
  submittedBy            User            @relation("HiddenGemSubmitter", fields: [submittedById], references: [id])
  logEntries             LogEntry[]      @relation("HiddenGemLogs")

  @@index([regionId])
  @@index([countryId])
  @@index([submittedById])
  @@index([status])
  @@index([waveType])
  @@index([difficulty])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Membership {
  id             String   @id @default(cuid())
  userId         String   @unique
  lemonSqueezyId String?
  variantId      Int?
  checkoutUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Board {
  id             String          @id @default(cuid())
  userId         String
  name           String
  type           BoardType
  length         Float
  finSetup       FinType
  images         String[]
  thumbnail      String?
  user           User            @relation(fields: [userId], references: [id])
  safariBookings SafariBooking[]

  @@index([userId])
}

model Forecast {
  id             String         @id @default(uuid())
  date           DateTime       @db.Date
  timeSlot       TimeSlot       @default(MORNING)
  regionId       String
  source         ForecastSource
  windSpeed      Int            @default(0)
  windDirection  Float          @default(0)
  swellHeight    Float          @default(0)
  swellPeriod    Int            @default(0)
  swellDirection Float          @default(0)
  trend          String?
  tide           String?
  alerts         Alert[]
  region         Region         @relation(fields: [regionId], references: [id])
  logEntries     LogEntry[]

  @@unique([date, regionId, source, timeSlot])
  @@index([regionId])
  @@index([source])
  @@index([date, regionId])
}

model Feedback {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  date         DateTime
  beachId      String
  conditions   Json
  improvements String?
  beach        Beach    @relation(fields: [beachId], references: [id])
}

model Story {
  id          String   @id @default(cuid())
  title       String
  details     String
  date        DateTime
  category    String
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  beachName   String?
  beachId     String?
  regionId    String?
  customBeach String?
  author      User     @relation(fields: [authorId], references: [id])
  beach       Beach?   @relation(fields: [beachId], references: [id])
  region      Region?  @relation(fields: [regionId], references: [id])

  @@index([authorId])
  @@index([beachId])
  @@index([regionId])
}

model UserFilters {
  id        String   @id @default(cuid())
  userEmail String   @unique
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  title     String   @db.VarChar(255)
  videoLink String   @db.VarChar(2048)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model RentalItem {
  id               String                   @id @default(cuid())
  name             String
  description      String?
  thumbnail        String?
  images           String[]
  isActive         Boolean                  @default(true)
  rentPrice        Float
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  userId           String
  itemType         String
  specifications   Json
  availableBeaches BeachRentalConnection[]
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability     RentalItemAvailability[]
  rentalRequests   RentalItemRequest[]

  @@index([userId])
  @@index([itemType])
  @@index([isActive])
}

model BeachRentalConnection {
  id           String     @id @default(cuid())
  rentalItemId String
  beachId      String
  beach        Beach      @relation(fields: [beachId], references: [id])
  rentalItem   RentalItem @relation(fields: [rentalItemId], references: [id], onDelete: Cascade)

  @@unique([rentalItemId, beachId])
  @@index([rentalItemId])
  @@index([beachId])
}

model RentalItemRequest {
  id                 String              @id @default(cuid())
  rentalItemId       String
  renterId           String
  ownerId            String
  status             RequestStatus       @default(PENDING)
  startDate          DateTime
  endDate            DateTime
  beachId            String
  totalCost          Json
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastActionAt       DateTime            @default(now())
  expiresAt          DateTime
  modificationCount  Int                 @default(0)
  previousVersions   Json?
  cancellationReason String?
  isExpired          Boolean             @default(false)
  hasBeenViewed      Boolean             @default(false)
  viewedAt           DateTime?
  paymentIntentId    String?
  depositPaid        Boolean             @default(false)
  messages           RentalChatMessage[]
  beach              Beach               @relation(fields: [beachId], references: [id])
  owner              User                @relation("OwnerItemRequests", fields: [ownerId], references: [id])
  rentalItem         RentalItem          @relation(fields: [rentalItemId], references: [id])
  renter             User                @relation("RenterItemRequests", fields: [renterId], references: [id])

  @@index([rentalItemId])
  @@index([renterId])
  @@index([ownerId])
  @@index([beachId])
  @@index([status])
}

model RentalItemAvailability {
  id           String     @id @default(cuid())
  rentalItemId String
  startDate    DateTime
  endDate      DateTime
  rentalItem   RentalItem @relation(fields: [rentalItemId], references: [id], onDelete: Cascade)

  @@index([rentalItemId])
}

model RentalChatMessage {
  id        String            @id @default(cuid())
  requestId String
  senderId  String
  content   String
  createdAt DateTime          @default(now())
  request   RentalItemRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    User              @relation(fields: [senderId], references: [id])

  @@index([requestId])
  @@index([senderId])
}

model Region {
  id               String            @id
  name             String
  countryId        String
  continent        String?
  ads              Ad[]
  adRequests       AdRequest[]
  alerts           Alert[]
  beaches          Beach[]
  beachDailyScores BeachDailyScore[]
  events           Event[]
  forecasts        Forecast[]
  hiddenGems       HiddenGem[]
  logEntries       LogEntry[]
  country          Country           @relation(fields: [countryId], references: [id])
  stories          Story[]
  searches         UserSearch[]
  properties       Property[]
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  entityId   String
  entityType String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityId, entityType])
}

model AdClick {
  id        String   @id @default(cuid())
  adId      String
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id])
}

model Alert {
  id                 String              @id @default(uuid())
  name               String
  beachId            String?
  regionId           String
  notificationMethod String
  contactInfo        String
  active             Boolean             @default(true)
  userId             String
  logEntryId         String?
  alertType          AlertType           @default(VARIABLES)
  starRating         Int?
  forecastDate       DateTime            @db.Date
  forecastId         String?
  sources            ForecastSource[]    @default([WINDFINDER])
  beach              Beach?              @relation(fields: [beachId], references: [id])
  forecast           Forecast?           @relation(fields: [forecastId], references: [id])
  logEntry           LogEntry?           @relation(fields: [logEntryId], references: [id])
  region             Region              @relation(fields: [regionId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  checks             AlertCheck[]        @relation("AlertChecks")
  notifications      AlertNotification[] @relation("AlertNotifications")
  properties         AlertProperty[]

  @@index([forecastId])
  @@index([logEntryId])
  @@index([userId])
  @@index([beachId])
  @@index([regionId])
}

model AlertCheck {
  id        String   @id @default(uuid())
  alertId   String
  checkedAt DateTime @default(now())
  success   Boolean
  details   String?
  alert     Alert    @relation("AlertChecks", fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([checkedAt])
}

model AlertNotification {
  id            String         @id @default(uuid())
  alertId       String
  success       Boolean
  details       String?
  createdAt     DateTime       @default(now())
  alertName     String?
  beachId       String?
  beachName     String?
  region        String?
  alert         Alert          @relation("AlertNotifications", fields: [alertId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([alertId])
  @@index([createdAt])
  @@index([region])
  @@index([beachId])
}

model Notification {
  id                  String             @id @default(uuid())
  userId              String
  type                String
  title               String
  message             String
  read                Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  alertNotificationId String?
  adId                String?
  adRequestId         String?
  ad                  Ad?                @relation(fields: [adId], references: [id])
  adRequest           AdRequest?         @relation(fields: [adRequestId], references: [id])
  alertNotification   AlertNotification? @relation(fields: [alertNotificationId], references: [id])
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
  @@index([alertNotificationId])
  @@index([adId])
  @@index([adRequestId])
}

model Continent {
  id        String    @id
  name      String
  countries Country[]
}

model Country {
  id          String      @id
  name        String
  continentId String
  beaches     Beach[]
  continent   Continent   @relation(fields: [continentId], references: [id])
  hiddenGems  HiddenGem[]
  regions     Region[]
}

model SponsorGlobal {
  id        String   @id @default(cuid())
  name      String
  logo      String
  link      String
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlertProperty {
  id           String @id @default(uuid())
  alertId      String
  property     String
  optimalValue Float
  range        Float
  alert        Alert  @relation(fields: [alertId], references: [id])

  @@index([alertId])
}

model UserSearch {
  id        String   @id @default(cuid())
  userId    String?
  regionId  String?
  beachId   String?
  createdAt DateTime @default(now())
  region    Region?  @relation(fields: [regionId], references: [id])
  beach     Beach?   @relation(fields: [beachId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Property {
  id              String              @id @default(cuid())
  title           String
  description     String
  beachId         String?
  regionId        String
  address         String?
  displayAddress  String
  coordinates     Json?
  hostId          String
  propertyType    PropertyType        @default(HOUSE)
  coverImageUrl   String?
  rules           String?
  checkInTime     String?
  checkOutTime    String?
  averageRating   Float?
  reviewCount     Int                 @default(0)
  bookingCount    Int                 @default(0)
  status          PropertyStatus      @default(DRAFT)
  published       Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  publishedAt     DateTime?
  units           AccommodationUnit[]
  beach           Beach?              @relation(fields: [beachId], references: [id])
  host            User                @relation("PropertyHost", fields: [hostId], references: [id])
  region          Region              @relation(fields: [regionId], references: [id])
  sharedAmenities PropertyAmenity[]
  images          PropertyImage[]
  reviews         PropertyReview[]    @relation("PropertyReviews")

  @@index([hostId])
  @@index([regionId])
  @@index([beachId])
  @@index([status, published])
  @@index([averageRating])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model AccommodationUnit {
  id                 String                @id @default(cuid())
  propertyId         String
  name               String
  description        String?
  unitType           AccommodationUnitType
  maxGuests          Int                   @default(2)
  numberOfBeds       Int?
  bedType            String?
  maxTents           Int?
  tentIncluded       Boolean               @default(false)
  pricePerNightCents Int
  cleaningFeeCents   Int                   @default(0)
  coverImageUrl      String?
  isActive           Boolean               @default(true)
  minimumNights      Int                   @default(1)
  maximumNights      Int?
  instantBookEnabled Boolean               @default(false)
  averageRating      Float?
  reviewCount        Int                   @default(0)
  bookingCount       Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  property           Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  enquiries          Enquiry[]
  unitAmenities      UnitAmenity[]
  availability       UnitAvailability[]
  blockedDates       UnitBlockedDate[]
  images             UnitImage[]

  @@index([propertyId])
  @@index([unitType])
  @@index([isActive])
  @@map("accommodation_units")
}

model UnitImage {
  id      String            @id @default(cuid())
  unitId  String
  url     String
  caption String?
  order   Int               @default(0)
  unit    AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("unit_images")
}

model Amenity {
  id                String            @id @default(cuid())
  name              String            @unique
  displayName       String
  category          AmenityCategory
  icon              String?
  propertyAmenities PropertyAmenity[]
  unitAmenities     UnitAmenity[]

  @@index([category])
  @@map("amenities")
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@index([propertyId])
  @@index([amenityId])
  @@map("property_amenities")
}

model UnitAmenity {
  id        String            @id @default(cuid())
  unitId    String
  amenityId String
  amenity   Amenity           @relation(fields: [amenityId], references: [id])
  unit      AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, amenityId])
  @@index([unitId])
  @@index([amenityId])
  @@map("unit_amenities")
}

model Booking {
  id                 String                @id @default(cuid())
  confirmationCode   String                @unique @default(cuid())
  unitId             String
  propertyId         String
  guestId            String
  hostId             String
  checkIn            DateTime
  checkOut           DateTime
  nights             Int
  numberOfGuests     Int
  numberOfTents      Int?
  guestMessage       String?
  pricePerNightCents Int
  totalNightsCents   Int
  cleaningFeeCents   Int                   @default(0)
  serviceFeeCents    Int                   @default(0)
  totalCents         Int
  paymentStatus      PaymentStatus         @default(PENDING)
  paymentMethod      String?
  paymentId          String?
  status             PropertyBookingStatus @default(PENDING)
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  confirmedAt        DateTime?
  completedAt        DateTime?
  guest              User                  @relation("BookingGuest", fields: [guestId], references: [id])
  unit               AccommodationUnit     @relation(fields: [unitId], references: [id])
  enquiry            Enquiry?              @relation("EnquiryConversion")
  messages           Message[]
  review             PropertyReview?       @relation("BookingReview")

  @@index([unitId])
  @@index([propertyId])
  @@index([guestId])
  @@index([hostId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Enquiry {
  id                   String            @id @default(cuid())
  unitId               String
  propertyId           String
  guestId              String
  hostId               String
  checkIn              DateTime
  checkOut             DateTime
  numberOfGuests       Int
  numberOfTents        Int?
  message              String
  status               EnquiryStatus     @default(PENDING)
  convertedToBookingId String?           @unique
  respondedAt          DateTime?
  responseTime         Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  expiresAt            DateTime?
  convertedToBooking   Booking?          @relation("EnquiryConversion", fields: [convertedToBookingId], references: [id])
  guest                User              @relation("EnquiryGuest", fields: [guestId], references: [id])
  unit                 AccommodationUnit @relation(fields: [unitId], references: [id])
  messages             Message[]

  @@index([unitId])
  @@index([propertyId])
  @@index([guestId])
  @@index([hostId])
  @@index([status])
  @@map("enquiries")
}

model Message {
  id         String    @id @default(cuid())
  enquiryId  String?
  bookingId  String?
  senderId   String
  content    String
  isFromHost Boolean
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  booking    Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  enquiry    Enquiry?  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  sender     User      @relation("MessageSender", fields: [senderId], references: [id])

  @@index([enquiryId])
  @@index([bookingId])
  @@index([senderId])
  @@map("messages")
}

model PropertyReview {
  id                  String     @id @default(cuid())
  propertyId          String
  bookingId           String     @unique
  reviewerId          String
  revieweeId          String
  type                ReviewType
  overallRating       Int
  cleanlinessRating   Int?
  communicationRating Int?
  accuracyRating      Int?
  valueRating         Int?
  locationRating      Int?
  comment             String?
  publicComment       String?
  privateComment      String?
  published           Boolean    @default(false)
  flagged             Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  publishedAt         DateTime?
  booking             Booking    @relation("BookingReview", fields: [bookingId], references: [id])
  property            Property   @relation("PropertyReviews", fields: [propertyId], references: [id])
  reviewee            User       @relation("Reviewee", fields: [revieweeId], references: [id])
  reviewer            User       @relation("Reviewer", fields: [reviewerId], references: [id])

  @@index([propertyId])
  @@index([bookingId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([type])
  @@map("property_reviews")
}

model UnitAvailability {
  id         String            @id @default(cuid())
  unitId     String
  date       DateTime
  available  Boolean           @default(true)
  priceCents Int?
  minNights  Int?
  unit       AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date])
  @@index([unitId])
  @@index([date])
  @@map("unit_availability")
}

model UnitBlockedDate {
  id        String            @id @default(cuid())
  unitId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime          @default(now())
  unit      AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("unit_blocked_dates")
}

