model Squad {
  id         String        @id @default(uuid())
  name       String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  members    SquadMember[]
  broadcasts Broadcast[]
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SquadMember {
  id          String   @id @default(uuid())
  squadId     String
  phoneNumber String // E.164 format: +1234567890
  name        String? // Optional name for the member
  createdAt   DateTime @default(now())
  squad       Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([squadId, phoneNumber])
  @@index([squadId])
}

model Broadcast {
  id          String          @id @default(uuid())
  squadId     String
  beachId     String?
  beachName   String? // Store beach name in case beach is deleted
  message     String
  scheduledAt DateTime // Date and time for when they're going surfing
  sentAt      DateTime? // When the broadcast was actually sent
  status      BroadcastStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  squad       Squad           @relation(fields: [squadId], references: [id], onDelete: Cascade)
  beach       Beach?          @relation(fields: [beachId], references: [id], onDelete: SetNull)

  @@index([squadId])
  @@index([beachId])
  @@index([status])
}

enum BroadcastStatus {
  PENDING
  SENT
  FAILED
}

model PromoCode {
  id          String            @id @default(cuid())
  code        String            @unique
  description String?
  isActive    Boolean           @default(true)
  maxUses     Int?              // null = unlimited
  usedCount   Int               @default(0)
  trialDays   Int               @default(30) // 1 month = 30 days
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  usages            PromoCodeUsage[]
  
  // Referral System
  discountPercent   Float?           @default(0)
  commissionPercent Float?           @default(0)
  ownerId           String?
  owner             User?            @relation("PartnerPromoCodes", fields: [ownerId], references: [id])

  @@index([code])
  @@index([isActive])
}

model PromoCodeUsage {
  id           String      @id @default(cuid())
  promoCodeId String
  userId       String
  usedAt       DateTime    @default(now())
  promoCode    PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@index([userId])
}


model PartnerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String?
  businessLink String?
  paypalEmail  String?
  balance      Float    @default(0)
  totalPaid    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Commission {
  id             String           @id @default(cuid())
  partnerId      String
  referredUserId String
  amount         Float
  currency       String           @default("USD")
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  paidAt         DateTime?
  partner        User             @relation("PartnerCommissions", fields: [partnerId], references: [id])
  referredUser   User             @relation("ReferredCommissions", fields: [referredUserId], references: [id])

  @@index([partnerId])
  @@index([status])
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

model EmailBlast {
  id        String               @id @default(cuid())
  name      String
  category  NotificationCategory
  sentAt    DateTime             @default(now())
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([category])
  @@index([sentAt])
}

model UserNotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  category  NotificationCategory
  isOptedIn Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

enum NotificationCategory {
  WEEKLY_INTEL
  TACTICAL_ALERTS
  PROMOTIONAL
  SYSTEM_UPDATES
}
