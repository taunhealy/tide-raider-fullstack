{
  "rules": [
    {
      "description": "Delete untagged images older than 3 days",
      "action": { "type": "DELETE" },
      "condition": {
        "tagState": "UNTAGGED",
        "olderThan": "3d"
      }
    },
    {
      "description": "Keep only last 5 tagged images per tag",
      "action": { "type": "DELETE" },
      "condition": {
        "tagState": "TAGGED",
        "olderThan": "14d"
      }
    }
  ]
}
